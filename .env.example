# ── Setup (required for npm run setup) ─────────────────────────────────────
FIRECRAWL_API_KEY=
ANTHROPIC_API_KEY=

# ── Database (Supabase) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_ALERTS_WEBHOOK=        # #gtm-alerts — real-time qualification alerts
SLACK_REVIEW_WEBHOOK=        # #signal-review — daily digest (optional, can be same channel)

# ── Reddit OAuth ─────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ── Serper (LinkedIn + Twitter scraping) ─────────────────────────────────────
SERPER_API_KEY=

# ── Enrichment (optional, post-qualification) ────────────────────────────────
LEADMAGIC_API_KEY=

# ── Google Sheets Dashboard ──────────────────────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=   # paste the entire JSON as a single line
